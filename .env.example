# Copy this file to .env and fill in values. NEVER commit your real .env.

# --- Flask ---
FLASK_ENV=development
SECRET_KEY=change-me-to-a-random-string

# --- Database (Postgres or SQLite) ---
# Postgres example: postgresql://localhost:5432/agentdb
# SQLite example:   sqlite:///agent.db
DATABASE_URL=sqlite:///agent.db

# --- Knowledge service: AnythingLLM (Project 1) ---
# Run AnythingLLM (see docs/anythingllm-setup.md), create a workspace, load the
# docs in sample-data/, then create a developer API key in its settings.
ANYTHINGLLM_BASE_URL=http://localhost:3001
ANYTHINGLLM_API_KEY=paste-your-anythingllm-api-key-here
ANYTHINGLLM_WORKSPACE=apprentice-kb

# --- Agent reasoning model (must support function/tool calling) ---
# Default: local + free via Ollama.
OLLAMA_BASE_URL=http://localhost:11434
AGENT_MODEL=llama3.1:8b
# Optional hosted upgrade for more reliable tool calling (Anthropic/OpenAI-compatible
# endpoint, e.g. MiniMax Token Plan). Leave blank to use Ollama above.
# AGENT_API_BASE_URL=
# AGENT_API_KEY=

# --- Agent guardrails ---
MAX_AGENT_STEPS=6
TOOL_TIMEOUT_SECONDS=20
